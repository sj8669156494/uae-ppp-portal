# ============================================================
# UAE PPP PORTAL — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Application
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-random-string-in-production

# Database
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./uae_ppp.db

# Production (PostgreSQL) — uncomment and fill in
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/uae_ppp

# OpenAI API (cheapest capable model: gpt-4o-mini)
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Scraping settings
SCRAPER_DELAY_SECONDS=2
SCRAPER_TIMEOUT_SECONDS=30
MAX_RETRIES=3
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; UAE-PPP-Bot/1.0; research)

# Scheduler
SCRAPER_SCHEDULE_HOUR=6
SCRAPER_SCHEDULE_MINUTE=0

# Monitoring
ENABLE_QUERY_LOGGING=true
LOG_FILE_PATH=logs/uae_ppp.log
